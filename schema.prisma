// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          Role      @default(USER)
  isVip         Boolean   @default(false) @map("is_vip")
  vipExpiresAt  DateTime? @map("vip_expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  predictions   Prediction[]
  subscriptions Subscription[]
  testimonials  Testimonial[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Prediction {
  id          String           @id @default(cuid())
  homeTeam    String           @map("home_team")
  awayTeam    String           @map("away_team")
  league      String
  matchDate   DateTime         @map("match_date")
  odds1X2     Json?            @map("odds_1x2") // {home: 1.5, draw: 4.2, away: 6.0}
  oddsOU      Json?            @map("odds_ou") // {over: 1.8, under: 1.9, line: 2.5}
  oddsBTTS    Json?            @map("odds_btts") // {yes: 1.7, no: 2.1}
  prediction  String           // 1, X, 2, Over, Under, BTTS, etc.
  predictionType PredictionType @map("prediction_type")
  confidence  Int              // 1-100
  analysis    String?          @db.Text
  status      Status           @default(PENDING)
  result      String?          // Actual result after match
  isVip       Boolean          @default(false) @map("is_vip")
  isFeatured  Boolean          @default(false) @map("is_featured")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  authorId    String           @map("author_id")

  author      User             @relation(fields: [authorId], references: [id])
  statistics  MatchStatistic?

  @@map("predictions")
}

model MatchStatistic {
  id            String     @id @default(cuid())
  predictionId  String     @unique @map("prediction_id")
  homeForm      String[]   @map("home_form") // ["W", "D", "L", "W", "W"]
  awayForm      String[]   @map("away_form")
  h2h           Json?      // Head to head stats
  homeGoalsAvg  Float?     @map("home_goals_avg")
  awayGoalsAvg  Float?     @map("away_goals_avg")
  leaguePosition Json?     @map("league_position")
  
  prediction    Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@map("match_statistics")
}

model Subscription {
  id            String             @id @default(cuid())
  userId        String             @map("user_id")
  plan          SubscriptionPlan
  status        SubscriptionStatus @default(ACTIVE)
  amount        Float
  currency      String             @default("USD")
  paymentMethod String             @map("payment_method") // stripe, mpesa, paypal
  transactionId String?            @map("transaction_id")
  startedAt     DateTime           @default(now()) @map("started_at")
  expiresAt     DateTime           @map("expires_at")
  createdAt     DateTime           @default(now()) @map("created_at")

  user          User               @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  content   String   @db.Text
  rating    Int      @default(5)
  isVisible Boolean  @default(false) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("testimonials")
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?
  coverImage  String?  @map("cover_image")
  category    String
  tags        String[]
  published   Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  authorId    String   @map("author_id")

  @@map("blog_posts")
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum PredictionType {
  MATCH_WINNER
  OVER_UNDER
  BTTS
  CORRECT_SCORE
  HT_FT
  HANDICAP
}

enum Status {
  PENDING
  WON
  LOST
  VOID
}

enum SubscriptionPlan {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}